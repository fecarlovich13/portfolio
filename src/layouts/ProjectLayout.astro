---
import BaseLayout from './BaseLayout.astro';
import ImageGallery from '../components/ImageGallery.astro';
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import { Image } from 'astro:assets';

const { entry } = Astro.props;
const { title, summary, institution, city, role, section, year, cover, gallery, tags } = entry.data;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const meta = [institution, city, String(year)].filter(Boolean).join(' — ');
const backPath = section === 'research-writing'
  ? '/projects/research-writing'
  : '/projects/exhibition-design';
---

<BaseLayout title={title} description={summary}>
  <article class="max-w-4xl mx-auto px-8 py-16">
    <a
      href={getLocalizedPath(lang, backPath)}
      class="text-sm text-stone-400 hover:text-stone-700 transition-colors mb-10 inline-block"
    >
      {t('project.backToProjects')}
    </a>

    <header class="mb-12">
      <h1 class="text-5xl font-light leading-tight mb-3" style="font-family: var(--font-serif)">{title}</h1>
      {meta && (
        <p class="text-stone-400 text-sm tracking-wide">{meta}</p>
      )}
      {role && (
        <p class="text-stone-400 text-xs mt-1 uppercase tracking-widest">{role}</p>
      )}
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag: string) => (
            <span class="text-xs text-stone-400 border border-stone-200 px-2 py-0.5 rounded-full">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {cover && (
      <div class="mb-12">
        <Image
          src={cover}
          alt={title}
          width={1200}
          height={800}
          class="w-full object-cover"
        />
      </div>
    )}

    {summary && (
      <div class="prose max-w-none mb-16 text-stone-700">
        <slot />
      </div>
    )}

    {!summary && <slot />}

    {gallery && gallery.length > 0 && (
      <ImageGallery images={gallery} alt={title} />
    )}
  </article>
</BaseLayout>
