---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="border-b border-stone-100">
  <nav class="max-w-screen-xl mx-auto px-8 py-5 flex items-center justify-between">
    <a href={getLocalizedPath(lang, '/')} class="text-lg font-light tracking-wide" style="font-family: var(--font-serif)">
      Fernanda Carlovich
    </a>
    <div class="flex items-center gap-8">
      <a href={getLocalizedPath(lang, '/projects/exhibition-design')} class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        {t('section.exhibition-design')}
      </a>
      <a href={getLocalizedPath(lang, '/projects/research-writing')} class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        {t('section.research-writing')}
      </a>
      <a href={getLocalizedPath(lang, '/info')} class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        {t('nav.info')}
      </a>
      <LanguageSwitcher />
    </div>
  </nav>
</header>
