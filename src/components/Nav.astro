---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header class="border-b border-stone-100">
  <nav class="max-w-5xl mx-auto px-6 py-5 flex items-center justify-between">
    <a href={getLocalizedPath(lang, '/')} class="font-serif text-lg font-light tracking-wide" style="font-family: var(--font-serif)">
      Fernanda Carlovich
    </a>
    <div class="flex items-center gap-8">
      <a href={getLocalizedPath(lang, '/projects')} class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        {t('nav.projects')}
      </a>
      <a href={getLocalizedPath(lang, '/about')} class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        {t('nav.about')}
      </a>
      <a href={getLocalizedPath(lang, '/contact')} class="text-sm text-stone-500 hover:text-stone-900 transition-colors">
        {t('nav.contact')}
      </a>
      <LanguageSwitcher />
    </div>
  </nav>
</header>
