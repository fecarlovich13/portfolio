---
import { Image } from 'astro:assets';

interface Props {
  images: ImageMetadata[];
  alt: string;
}

const { images, alt } = Astro.props;
---

<section class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  {images.map((img, i) => (
    <div class="overflow-hidden bg-stone-100">
      <Image
        src={img}
        alt={`${alt} — ${i + 1}`}
        width={800}
        height={600}
        class="w-full h-full object-cover"
      />
    </div>
  ))}
</section>
