---
import { getCollection, render } from 'astro:content';
import ProjectLayout from '../../../layouts/ProjectLayout.astro';

export async function getStaticPaths() {
  const en = await getCollection('projects', ({ id }) => id.startsWith('en/'));
  const pt = await getCollection('projects', ({ id }) => id.startsWith('pt/'));
  const all = [...en, ...pt];
  return all.map((entry) => {
    const [lang, ...rest] = entry.id.split('/');
    const slug = rest.join('/');
    return { params: { lang, slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<ProjectLayout entry={entry}>
  <Content />
</ProjectLayout>
