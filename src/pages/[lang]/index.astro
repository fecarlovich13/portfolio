---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'en' | 'pt');

const allProjects = await getCollection('projects', ({ id }) => id.startsWith(`${lang}/`));
const sorted = allProjects.sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order);

const exhibitionDesign = sorted.filter((p) => p.data.section === 'exhibition-design');
const researchWriting = sorted.filter((p) => p.data.section === 'research-writing');
---

<BaseLayout title={t('nav.home')}>
  <section class="max-w-5xl mx-auto px-6 py-20">
    <div class="mb-20">
      <h1 class="text-6xl font-light leading-tight" style="font-family: var(--font-serif)">
        Fernanda Carlovich
      </h1>
    </div>

    {exhibitionDesign.length > 0 && (
      <div class="mb-20">
        <h2 class="text-xs uppercase tracking-widest text-stone-400 mb-8">{t('section.exhibition-design')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
          {exhibitionDesign.map((project) => {
            const slug = project.id.replace(`${lang}/`, '');
            return (
              <ProjectCard
                title={project.data.title}
                summary={project.data.summary}
                institution={project.data.institution}
                city={project.data.city}
                year={project.data.year}
                cover={project.data.cover}
                slug={slug}
              />
            );
          })}
        </div>
      </div>
    )}

    {researchWriting.length > 0 && (
      <div>
        <h2 class="text-xs uppercase tracking-widest text-stone-400 mb-8">{t('section.research-writing')}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
          {researchWriting.map((project) => {
            const slug = project.id.replace(`${lang}/`, '');
            return (
              <ProjectCard
                title={project.data.title}
                summary={project.data.summary}
                institution={project.data.institution}
                city={project.data.city}
                year={project.data.year}
                cover={project.data.cover}
                slug={slug}
              />
            );
          })}
        </div>
      </div>
    )}
  </section>
</BaseLayout>
