---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'en' | 'pt');

const allProjects = await getCollection('projects', ({ id }) => id.startsWith(`${lang}/`));
const sorted = allProjects.sort((a, b) => b.data.year - a.data.year || a.data.order - b.data.order);
---

<BaseLayout title={t('nav.home')}>
  <section class="max-w-screen-xl mx-auto px-8 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {sorted.map((project) => {
        const slug = project.id.replace(`${lang}/`, '');
        return (
          <ProjectCard
            title={project.data.title}
            summary={project.data.summary}
            institution={project.data.institution}
            city={project.data.city}
            year={project.data.year}
            cover={project.data.cover}
            slug={slug}
          />
        );
      })}
    </div>
  </section>
</BaseLayout>
