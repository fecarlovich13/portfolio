---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/utils';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'pt' } }];
}

const { lang } = Astro.params;
const t = useTranslations(lang as 'en' | 'pt');

const content = {
  en: {
    bio: `Fernanda Carlovich is an artist based in [your city]. Her work explores [your themes].

She has exhibited at [galleries/institutions]. Her practice spans [mediums].`,
  },
  pt: {
    bio: `Fernanda Carlovich é uma artista baseada em [sua cidade]. Seu trabalho explora [seus temas].

Ela já expôs em [galerias/instituições]. Sua prática abrange [meios].`,
  },
};
---

<BaseLayout title={t('about.title')}>
  <section class="max-w-2xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-light mb-12" style="font-family: var(--font-serif)">{t('about.title')}</h1>
    <div class="prose text-stone-700">
      {content[lang as 'en' | 'pt'].bio.split('\n\n').map((para) => (
        <p>{para}</p>
      ))}
    </div>
  </section>
</BaseLayout>
